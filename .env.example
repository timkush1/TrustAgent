# TruthTable Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git

# Grafana admin password (REQUIRED - compose refuses to start without it)
GRAFANA_ADMIN_PASSWORD=

# Postgres password for the audit-history database
# (defaults to truthtable-dev for local development; set a real one in prod)
POSTGRES_PASSWORD=

# Upstream LLM URL (defaults to local Ollama)
UPSTREAM_LLM_URL=http://ollama:11434

# ========== Proxy security ==========

# Comma-separated API keys for /v1/* and /api/* endpoints.
# Empty = authentication DISABLED (local development only!).
# Generate with e.g.:  openssl rand -hex 32
TRUTHTABLE_API_KEYS=

# Comma-separated origins allowed for CORS and WebSocket connections.
TRUTHTABLE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limits (requests per minute per client; client = API key or IP)
# TRUTHTABLE_RATE_LIMIT_PER_MINUTE=120
# TRUTHTABLE_UPLOAD_LIMIT_PER_MINUTE=10

# Request size caps
# TRUTHTABLE_MAX_BODY_BYTES=1048576       # 1 MiB
# TRUTHTABLE_MAX_UPLOAD_BYTES=10485760    # 10 MiB
# TRUTHTABLE_MAX_TEXT_CHARS=20000
